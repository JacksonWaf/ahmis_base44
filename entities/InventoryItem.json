{
  "name": "InventoryItem",
  "type": "object",
  "properties": {
    "facility_id": {
      "type": "string",
      "description": "Facility this item belongs to"
    },
    "name": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "medical_supplies",
        "surgical",
        "ppe",
        "cleaning",
        "office",
        "linen",
        "food",
        "other"
      ]
    },
    "sku": {
      "type": "string"
    },
    "unit": {
      "type": "string",
      "enum": [
        "pieces",
        "boxes",
        "packets",
        "liters",
        "kg",
        "rolls",
        "pairs",
        "sets"
      ]
    },
    "quantity_in_stock": {
      "type": "number",
      "default": 0
    },
    "reorder_level": {
      "type": "number",
      "default": 20
    },
    "unit_cost": {
      "type": "number"
    },
    "supplier": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "last_restocked": {
      "type": "string",
      "format": "date"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_stock",
        "low_stock",
        "out_of_stock",
        "discontinued"
      ],
      "default": "in_stock"
    }
  },
  "required": [
    "name",
    "sku"
  ]
}