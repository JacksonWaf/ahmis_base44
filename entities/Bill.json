{
  "name": "Bill",
  "type": "object",
  "properties": {
    "facility_id": {
      "type": "string",
      "description": "Facility this bill belongs to"
    },
    "patient_id": {
      "type": "string"
    },
    "patient_name": {
      "type": "string"
    },
    "bill_number": {
      "type": "string"
    },
    "bill_date": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax": {
      "type": "number"
    },
    "discount": {
      "type": "number"
    },
    "total_amount": {
      "type": "number"
    },
    "amount_paid": {
      "type": "number",
      "default": 0
    },
    "insurance_covered": {
      "type": "number",
      "default": 0
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "card",
        "insurance",
        "bank_transfer",
        "mobile_money"
      ]
    },
    "notes": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "pending",
        "partially_paid",
        "paid",
        "overdue",
        "cancelled"
      ],
      "default": "draft"
    }
  },
  "required": [
    "patient_name"
  ]
}